# Local-dev secrets template. Copy to `.env` and fill in. NEVER commit `.env`.
#
# Production secrets live in GitHub Actions secrets:
#   https://github.com/zetoroz/nexusmortgage.sg/settings/secrets/actions

# MAS API key issued at https://eservices.mas.gov.sg/apimg-portal/
# Header name defaults to "keyId"; override via MAS_API_KEY_HEADER if MAS docs say otherwise.
MAS_API_KEY=
MAS_API_KEY_HEADER=keyId

# Optional override of the SORA endpoint URL.
# If unset, scripts/fetch-mas-rates.mjs uses the documented default.
MAS_API_URL=
